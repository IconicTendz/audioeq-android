<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="audioeq.db" />
        <include domain="sharedpref" path="audioeq_preferences.xml" />
        <include domain="file" path="settings/" />
        <include domain="file" path="presets/" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="audioeq.db" />
        <include domain="sharedpref" path="*" />
        <include domain="file" path="settings/" />
        <include domain="file" path="presets/" />
    </device-transfer>
</data-extraction-rules>
